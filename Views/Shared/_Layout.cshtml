<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>@ViewBag.Title</title>
    <link rel="stylesheet" href="~/css/output.css" />
</head>
<body class="bg-gray-100 min-h-screen">
    <nav class="bg-indigo-600 shadow-lg">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16">
                <div class="flex items-center">
                    <a href="/" class="text-white text-xl font-bold">Many2Many</a>
                    <div class="ml-10 flex items-baseline space-x-4">
                        <a asp-controller="Books" asp-action="Index" class="text-gray-200 hover:text-white px-3 py-2 rounded-md text-sm font-medium">Books</a>
                        <a asp-controller="Authors" asp-action="Index" class="text-gray-200 hover:text-white px-3 py-2 rounded-md text-sm font-medium">Authors</a>
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <main class="max-w-7xl mx-auto py-6 sm:px-6 lg:px-8">
        @RenderBody()
    </main>

    <footer class="bg-gray-800 text-gray-400 py-4 mt-8">
        <div class="max-w-7xl mx-auto text-center">
            <p>&copy; @DateTime.Now.Year - Many2Many Application</p>
        </div>
    </footer>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
