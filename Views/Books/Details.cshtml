@model BookViewModel
@{
    ViewData["Title"] = "Book Details";
}


<div class="px-4 sm:px-0">
    <div class="mb-6">
        <a asp-action="Index" class="text-indigo-600 hover:text-indigo-900 flex items-center">
            <svg class="w-5 h-5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
            </svg>
            Back to Books
        </a>
    </div>

    <div class="bg-white shadow-lg rounded-lg overflow-hidden">
        <div class="px-6 py-4 bg-gradient-to-r from-indigo-500 to-purple-600">
            <h1 class="text-2xl font-bold text-white">@Model.Title</h1>
        </div>

        <div class="p-6">
            <div class="mb-6">
                <h2 class="text-lg font-semibold text-gray-900 mb-3">Current Authors</h2>
                @if (Model.CurrentAuthors.Count > 0)
                {
                    <div class="flex flex-wrap gap-2">
                        @foreach (var author in Model.CurrentAuthors)
                        {
                            <a asp-controller="Authors" asp-action="Details" asp-route-id="@author.AuthorId"
                                   class="inline-flex items-center px-3 py-1.5 rounded-full text-sm font-medium bg-indigo-100 text-indigo-800 hover:bg-indigo-200 transition duration-150 ease-in-out">
                                @author.Name
                            </a>
                        }
                    </div>
                }
                else
                {
                    <p class="text-gray-500 italic">No authors assigned to this book.</p>
                }
            </div>

            <hr class="my-6 border-gray-200" />

            <div>
                <h2 class="text-lg font-semibold text-gray-900 mb-3">Manage Authors</h2>
                <form asp-action="UpdateAuthors" asp-route-id="@Model.BookId" method="post">
                    @Html.AntiForgeryToken()
                    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-3 mb-4">
                        @foreach (var author in Model.AvailableAuthors)
                        {
                            <label class="flex items-center p-3 bg-gray-50 rounded-lg hover:bg-gray-100 cursor-pointer transition duration-150 ease-in-out">
                                <input type="checkbox"
                                       name="selectedAuthorIds"
                                       value="@author.AuthorId"
                                @(Model.SelectedAuthorIds.Contains(author.AuthorId) ? "checked" : "")
                                       class="h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded" />
                                <span class="ml-2 text-sm text-gray-700">@author.Name</span>
                            </label>
                        }
                    </div>
                    <button type="submit" class="inline-flex items-center px-4 py-2 bg-green-600 hover:bg-green-700 text-white font-semibold rounded-lg shadow-md transition duration-150 ease-in-out">
                        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                        </svg>
                        Update Authors
                    </button>
                </form>
            </div>
        </div>

        <div class="px-6 py-4 bg-gray-50 flex justify-end space-x-3">
            <a asp-action="Edit" asp-route-id="@Model.BookId" class="inline-flex items-center px-4 py-2 bg-yellow-500 hover:bg-yellow-600 text-white font-semibold rounded-lg shadow-md transition duration-150 ease-in-out">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                </svg>
                Edit Book
            </a>
            <a asp-action="Delete" asp-route-id="@Model.BookId" class="inline-flex items-center px-4 py-2 bg-red-600 hover:bg-red-700 text-white font-semibold rounded-lg shadow-md transition duration-150 ease-in-out">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                </svg>
                Delete
            </a>
        </div>
    </div>
</div>
