@model BookViewModel
@{
    ViewData["Title"] = "Edit Book";
}


<div class="px-4 sm:px-0">
    <div class="mb-6">
        <a asp-action="Index" class="text-indigo-600 hover:text-indigo-900 flex items-center">
            <svg class="w-5 h-5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
            </svg>
            Back to Books
        </a>
    </div>

    <div class="bg-white shadow-lg rounded-lg overflow-hidden max-w-2xl">
        <div class="px-6 py-4 bg-gradient-to-r from-yellow-500 to-orange-500">
            <h1 class="text-2xl font-bold text-white">Edit Book</h1>
        </div>

        <form asp-action="Edit" method="post" class="p-6">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="BookId" />
            
            <div class="mb-6">
                <label asp-for="Title" class="block text-sm font-medium text-gray-700 mb-2">Title</label>
                <input asp-for="Title" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-yellow-500 focus:border-yellow-500 transition duration-150 ease-in-out" placeholder="Enter book title" />
                <span asp-validation-for="Title" class="text-red-500 text-sm mt-1"></span>
            </div>

            <div class="mb-6">
                <label class="block text-sm font-medium text-gray-700 mb-2">Authors</label>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 max-h-60 overflow-y-auto p-2 border border-gray-200 rounded-lg">
                    @foreach (var author in Model.AvailableAuthors)
                    {
                        <label class="flex items-center p-2 bg-gray-50 rounded-lg hover:bg-gray-100 cursor-pointer transition duration-150 ease-in-out">
                            <input type="checkbox"
                                   name="SelectedAuthorIds"
                                   value="@author.AuthorId"
                            @(Model.SelectedAuthorIds.Contains(author.AuthorId) ? "checked" : "")
                                   class="h-4 w-4 text-yellow-600 focus:ring-yellow-500 border-gray-300 rounded" />
                            <span class="ml-2 text-sm text-gray-700">@author.Name</span>
                        </label>
                    }
                </div>
            </div>

            <div class="flex justify-end space-x-3">
                <a asp-action="Index" class="px-4 py-2 bg-gray-300 hover:bg-gray-400 text-gray-800 font-semibold rounded-lg transition duration-150 ease-in-out">
                    Cancel
                </a>
                <button type="submit" class="px-4 py-2 bg-yellow-500 hover:bg-yellow-600 text-white font-semibold rounded-lg shadow-md transition duration-150 ease-in-out">
                    Save Changes
                </button>
            </div>
        </form>
    </div>
</div>
